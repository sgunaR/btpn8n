# Non-sensitive local defaults
NODE_ENV=production
N8N_HOST=0.0.0.0
N8N_PORT=8080
N8N_PROTOCOL=https

# Populated by: npm run secrets:pull -- --service <postgres-service-name>
DB_TYPE=postgresdb
DB_POSTGRESDB_HOST=
DB_POSTGRESDB_PORT=
DB_POSTGRESDB_DATABASE=
DB_POSTGRESDB_USER=
DB_POSTGRESDB_PASSWORD=
DB_POSTGRESDB_SSL=true
DB_POSTGRESDB_SSL_REJECT_UNAUTHORIZED=false
